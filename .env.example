# Production build only (npm run build) — include /api suffix
# VITE_API_BASE_URL=https://loyverse-api-backend-2.onrender.com/api
#
# Local dev (npm run dev): leave unset — app uses /api + Vite proxy (no CORS issues).
# Do NOT point VITE_API_BASE_URL at Render during dev unless backend CORS allows localhost:5173.
