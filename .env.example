# Copy to .env and fill in real values. Do not commit .env to Git.
# Vite only exposes variables prefixed with VITE_ to the client.
# Keep API secrets on a backend/proxy — do not put private keys in VITE_* vars.

# Loyverse API (when integrated)
VITE_LOYVERSE_API_BASE_URL=
VITE_LOYVERSE_STORE_ID=

# Optional: server-side only (use with a backend, not VITE_ prefix in production)
# LOYVERSE_ACCESS_TOKEN=
